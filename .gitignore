# ── Dependencies ─────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*

# Yarn Berry
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Python backend ───────────────────────────────────────────────
/python_backend/__pycache__/
/python_backend/venv/
/python_backend/.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Test artifacts ───────────────────────────────────────────────
/coverage
/.pytest_cache/
/tests/__pycache__/
*.log
pytest.ini    # keep locally, don't expose test config

# ── Environment files ────────────────────────────────────────────
# Commit .env.example (safe template), ignore everything else
.env
.env.*
!.env.example

# ── Vercel ───────────────────────────────────────────────────────
.vercel

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Logs & debug ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS / editor junk ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.pem

# VS Code (keep workspace settings if you want, ignore user-specific)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs
.idea/

# ── Misc ─────────────────────────────────────────────────────────
*.tgz
*.tar.gz
